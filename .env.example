# ── EggSort AI — Environment Configuration ────────────────────────────────
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าตามต้องการ
# cp .env.example .env

# [จำเป็น] Anthropic API Key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# กล้อง
CAMERA_INDEX=0
CAPTURE_WIDTH=2592
CAPTURE_HEIGHT=1944
CAPTURE_INTERVAL=2.0

# Server
HTTP_PORT=8080
WS_PORT=8765
WS_HOST=0.0.0.0

# บันทึกภาพ (true/false)
SAVE_IMAGES=true
